# Detec Central Server — environment variables
# Copy to .env and fill in your values before running.
# See SERVER.md for full documentation.

# ── Required ──────────────────────────────────────────────

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# Password for the seed admin user (created on first startup)
SEED_ADMIN_PASSWORD=CHANGE_ME_PICK_A_STRONG_PASSWORD

# ── Database ──────────────────────────────────────────────
# The API defaults to a local SQLite database (zero setup).
# Uncomment the lines below to use PostgreSQL instead.

# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD
# POSTGRES_DB=agentic_governance
# DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/agentic_governance

# ── Optional ──────────────────────────────────────────────

# Environment: development | staging | production
# In staging/production, default JWT_SECRET and SEED_ADMIN_PASSWORD are rejected.
# ENV=development

# Seed admin email and tenant name
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_TENANT_NAME=Default

# Pinned seed keys (auto-generated by detec-server setup, preserved across reinstalls).
# When set, _seed() uses these instead of generating random keys, so agents survive
# server reinstalls without reconfiguration.
# SEED_API_KEY=
# SEED_AGENT_KEY=

# CORS origins (development). Comma-separated list of allowed origins.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# In production, ALLOWED_ORIGINS is required (comma-separated). CORS_ORIGINS is ignored.
# ALLOWED_ORIGINS=https://dashboard.example.com,https://app.example.com

# API bind address and port
# API_HOST=0.0.0.0
# API_PORT=8000

# JWT token lifetimes
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=30

# Default heartbeat interval (seconds) for new endpoints
# DEFAULT_HEARTBEAT_INTERVAL=300

# Debug mode (do not enable in production)
# DEBUG=false

# Skip automatic Alembic migrations on Docker container start
# RUN_MIGRATIONS=true

# ── Webhooks ──────────────────────────────────────────────
# Outbound HTTP webhooks for event notifications.
# Configure webhook endpoints via the dashboard Settings page or REST API.

# WEBHOOK_DELIVERY_TIMEOUT=10
# WEBHOOK_MAX_RETRIES=3

# ── Binary Protocol Gateway ──────────────────────────────
# The gateway provides a persistent TCP connection for agents using the
# binary wire protocol (msgpack framing, port 8001). Enable it alongside
# the HTTP API when agents use --protocol tcp.

# GATEWAY_ENABLED=true
# GATEWAY_HOST=0.0.0.0
# GATEWAY_PORT=8001
# GATEWAY_TLS_CERT=
# GATEWAY_TLS_KEY=

# ── EDR Integration ───────────────────────────────────────
# Server-side enrichment of detection events via enterprise EDR platforms.
# When enabled, the server queries CrowdStrike (or other EDR) for process
# and network events around each detection to rescore confidence.

# EDR_PROVIDER=crowdstrike
# EDR_API_BASE=https://api.crowdstrike.com
# EDR_CLIENT_ID=
# EDR_CLIENT_SECRET=
# EDR_ENRICHMENT_ENABLED=false
# EDR_QUERY_WINDOW_BEFORE_SECONDS=300
# EDR_QUERY_WINDOW_AFTER_SECONDS=60

# EDR enforcement (delegated kill/contain via EDR).
# When enabled, the server registers the CrowdStrike enforcement provider
# at startup and routes enforcement decisions through it before falling back
# to the local agent. Requires EDR_PROVIDER + credentials above.
# EDR_ENFORCEMENT_ENABLED=false
# EDR_ENFORCEMENT_FALLBACK=local

# ── Stripe Billing ────────────────────────────────────────
# Stripe integration for subscription management (self-service upgrades).
# All four settings are required to enable the billing portal.

# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_ENTERPRISE=price_...

# ── SMTP (Email Enrollment) ──────────────────────────────
# When configured, admins can send agent download links to end users via email.
# Both SMTP_HOST and SMTP_FROM are required to enable email enrollment.

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true
