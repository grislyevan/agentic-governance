# Detec Central Server — environment variables
# Copy to .env and fill in your values before running.
# See SERVER.md for full documentation.

# ── Required ──────────────────────────────────────────────

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# Password for the seed admin user (created on first startup)
SEED_ADMIN_PASSWORD=CHANGE_ME_PICK_A_STRONG_PASSWORD

# ── Database ──────────────────────────────────────────────
# The API defaults to a local SQLite database (zero setup).
# Uncomment the lines below to use PostgreSQL instead.

# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD
# POSTGRES_DB=agentic_governance
# DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/agentic_governance

# ── Optional ──────────────────────────────────────────────

# Environment: development | staging | production
# In staging/production, default JWT_SECRET and SEED_ADMIN_PASSWORD are rejected.
# ENV=development

# Seed admin email and tenant name
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_TENANT_NAME=Default

# CORS origins (comma-separated or JSON array). Set to your dashboard URL in production.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# API bind address and port
# API_HOST=0.0.0.0
# API_PORT=8000

# JWT token lifetimes
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=30

# Default heartbeat interval (seconds) for new endpoints
# DEFAULT_HEARTBEAT_INTERVAL=300

# Debug mode (do not enable in production)
# DEBUG=false

# Skip automatic Alembic migrations on Docker container start
# RUN_MIGRATIONS=true
