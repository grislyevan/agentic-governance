# Detec Production Environment Template
# Copy to .env in the repo root and fill in values before deploying.
# Values marked MUST CHANGE must be set before the API will start in production.

# =============================================================================
# MUST CHANGE (required for ENV=production)
# =============================================================================

# JWT signing secret. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# Password for the seed admin user (created on first startup)
SEED_ADMIN_PASSWORD=CHANGE_ME_PICK_A_STRONG_PASSWORD

# Email for the seed admin user
SEED_ADMIN_EMAIL=admin@example.com

# Comma-separated list of allowed dashboard origins (no wildcards in production)
# Example: https://detec.example.com,https://app.example.com
ALLOWED_ORIGINS=https://your-domain.com

# =============================================================================
# Database (PostgreSQL)
# =============================================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_A_STRONG_PASSWORD
POSTGRES_DB=agentic_governance

# =============================================================================
# Caddy / TLS
# =============================================================================

# Domain for Caddy TLS. Set to your public hostname (e.g. detec.example.com).
# Caddy will obtain and renew Let's Encrypt certificates automatically.
# Use localhost for local testing (no TLS).
DOMAIN=localhost

# =============================================================================
# Optional (sensible defaults)
# =============================================================================

# Seed tenant name
# SEED_TENANT_NAME=Default

# Pinned seed keys. When set, preserved across server reinstalls.
# SEED_API_KEY=
# SEED_AGENT_KEY=

# Default heartbeat interval for new endpoints (seconds)
# DEFAULT_HEARTBEAT_INTERVAL=300

# Retention and privacy
# DEFAULT_RETENTION_DAYS=90
# STALE_THRESHOLD_DAYS=30

# Webhooks
# WEBHOOK_DELIVERY_TIMEOUT=10
# WEBHOOK_MAX_RETRIES=3

# =============================================================================
# Optional (EDR, SMTP, MDM)
# =============================================================================

# EDR_PROVIDER=crowdstrike
# EDR_API_BASE=https://api.crowdstrike.com
# EDR_CLIENT_ID=
# EDR_CLIENT_SECRET=
# EDR_ENRICHMENT_ENABLED=false

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
