# This file is for local (non-Docker) development only.
# For the canonical variable reference, see the root .env.example and SERVER.md.
#
# Quick start:
#   cp .env.example .env
#   cd api && uvicorn main:app --reload
#
# The API defaults to SQLite. Set DATABASE_URL to use PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic_governance

JWT_SECRET=dev-only-not-for-production
SEED_ADMIN_PASSWORD=change-me
SEED_ADMIN_EMAIL=admin@example.com
SEED_TENANT_NAME=Default
# SEED_API_KEY=
# SEED_AGENT_KEY=
ENV=development

# Demo mode: seeds sample endpoints, events, and enforcement data on startup.
# Useful for sales demos and evaluation. Set to true to enable.
# DEMO_MODE=false

# In production, set ALLOWED_ORIGINS (comma-separated list of dashboard URLs).
# ALLOWED_ORIGINS=https://dashboard.example.com

# Webhooks
# WEBHOOK_DELIVERY_TIMEOUT=10
# WEBHOOK_MAX_RETRIES=3

# Binary protocol gateway (TCP, port 8001)
# GATEWAY_ENABLED=true
# GATEWAY_PORT=8001

# EDR integration (server-side enrichment)
# EDR_PROVIDER=crowdstrike
# EDR_API_BASE=https://api.crowdstrike.com
# EDR_CLIENT_ID=
# EDR_CLIENT_SECRET=
# EDR_ENRICHMENT_ENABLED=false

# EDR enforcement (delegated kill/contain via EDR)
# Requires EDR_PROVIDER + credentials above to be set.
# EDR_ENFORCEMENT_ENABLED=false
# EDR_ENFORCEMENT_FALLBACK=local

# SMTP (email enrollment)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=noreply@example.com

# Stripe Billing (see root .env.example for full docs)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PUBLISHABLE_KEY=pk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_PRO=price_...
# STRIPE_PRICE_ID_ENTERPRISE=price_...
